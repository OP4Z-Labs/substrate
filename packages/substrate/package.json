{
  "name": "@op4z/substrate",
  "version": "3.0.0-beta.1",
  "description": "Repeatable automation patterns for codebases. Audits, scaffolds, standards, and bridges to AI coding assistants.",
  "license": "MIT",
  "author": "Beau Goldberg",
  "homepage": "https://github.com/op4z-labs/substrate",
  "repository": {
    "type": "git",
    "url": "https://github.com/op4z-labs/substrate.git"
  },
  "bugs": {
    "url": "https://github.com/op4z-labs/substrate/issues"
  },
  "type": "module",
  "bin": {
    "substrate": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "templates-history",
    "schemas",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\" \"*.json\"",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"tests/integration/**\"",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "smoke:enterprise": "bash tests/smoke/enterprise-smoke.sh",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/copy-changelog.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "automation",
    "audit",
    "scaffold",
    "standards",
    "cli",
    "shadcn-style",
    "claude-code",
    "codebase-audit",
    "workflow-runtime",
    "substrate"
  ]
}
