{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://op4z.dev/substrate/schemas/config.schema.json",
  "title": "Substrate Project Configuration",
  "description": "Schema for `substrate.config.json` at the consumer repo root. Mirrors the runtime SubstrateConfig type. Additive: v2 fields (e.g. memory.path) are optional so older configs continue to validate.",
  "type": "object",
  "required": ["version", "project", "stacks", "paths", "defaults", "bridges", "telemetry"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "description": "Substrate config schema version this file was written against.",
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "shortCode": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "stacks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "paths": {
      "type": "object",
      "required": ["auto"],
      "additionalProperties": true,
      "properties": {
        "backend": { "type": "string" },
        "frontend": { "type": "string" },
        "packagesTs": { "type": "string" },
        "packagesPython": { "type": "string" },
        "docs": { "type": "string" },
        "auto": { "type": "string" }
      }
    },
    "defaults": {
      "type": "object",
      "required": ["audits", "standards", "scaffolds", "workflows"],
      "additionalProperties": true,
      "properties": {
        "audits": { "type": "array", "items": { "type": "string" } },
        "standards": { "type": "array", "items": { "type": "string" } },
        "scaffolds": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" } }
      }
    },
    "bridges": {
      "type": "object",
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" } },
        "redactPatterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "taskAdapter": { "type": ["string", "null"] },
        "vcsAdapter": { "type": ["string", "null"] }
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "memory": {
      "description": "v2.0 memory subsystem configuration. Optional; when omitted, substrate falls back to $SUBSTRATE_MEMORY_PATH then Claude Code's default directory (~/.claude/projects/<encoded>/memory/). See plan §6.1.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "description": "Absolute or repo-relative path to the memory store directory. Memories are expected to be `*.md` files with optional YAML frontmatter; see plan §6.2 for the extended frontmatter shape.",
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
