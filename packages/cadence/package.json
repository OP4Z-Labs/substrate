{
  "name": "cadence",
  "version": "0.8.0",
  "description": "Repeatable automation patterns for codebases. Audits, scaffolds, standards, and bridges to AI coding assistants.",
  "license": "MIT",
  "author": "Beau Goldberg",
  "type": "module",
  "bin": {
    "cadence": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "templates-history",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\" \"*.json\"",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"tests/integration/**\"",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "yaml": "^2.9.0"
  },
  "keywords": [
    "automation",
    "audit",
    "scaffold",
    "standards",
    "cli",
    "shadcn-style",
    "claude-code"
  ]
}
