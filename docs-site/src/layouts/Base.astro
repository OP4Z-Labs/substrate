---
/**
 * Base layout for substrate docs pages.
 *
 * Minimal: tab title, simple nav, content slot, footer with licensing
 * notice. No JS, no client-side framework — pure Astro static pages.
 *
 * Licensing notice (per the v0.8 brief):
 *   - Code (substrate package + adapters): MIT
 *   - Content (standards docs, audit playbooks, this docs site): CC-BY 4.0
 * Documented in the footer + a LICENSES file at the repo root.
 */
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const navItems = [
  { label: "Home", href: "/" },
  { label: "Quick Start", href: "/quick-start/" },
  { label: "Commands", href: "/commands/" },
  { label: "Audits", href: "/audits/" },
  { label: "Standards", href: "/standards/" },
  { label: "Plugin Authoring", href: "/plugin-authoring/" },
  { label: "FAQ", href: "/faq/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Substrate</title>
    {description && <meta name="description" content={description} />}
    <style is:global>
      :root {
        --color-text: #1a1a1a;
        --color-muted: #5a5a5a;
        --color-bg: #fbfbfb;
        --color-link: #6e3fd7;
        --color-border: #e6e6e6;
        --max-width: 760px;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.6;
      }
      header {
        border-bottom: 1px solid var(--color-border);
        background: white;
      }
      header .container,
      main,
      footer .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      header .container {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding-top: 1rem;
        padding-bottom: 1rem;
        flex-wrap: wrap;
      }
      header .brand {
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--color-text);
        text-decoration: none;
      }
      header nav {
        display: flex;
        gap: 1rem;
        font-size: 0.95rem;
        flex-wrap: wrap;
      }
      header nav a {
        color: var(--color-muted);
        text-decoration: none;
      }
      header nav a:hover {
        color: var(--color-link);
      }
      main {
        padding-top: 2.5rem;
        padding-bottom: 4rem;
      }
      main h1 {
        margin-top: 0;
        font-size: 2rem;
      }
      main h2 {
        margin-top: 2.5rem;
        font-size: 1.4rem;
      }
      main a {
        color: var(--color-link);
      }
      main code {
        background: #f0eaff;
        padding: 0.1rem 0.35rem;
        border-radius: 3px;
        font-size: 0.9em;
      }
      main pre {
        background: #1e1e1e;
        color: #f5f5f5;
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
        font-size: 0.85rem;
      }
      main pre code {
        background: transparent;
        padding: 0;
        color: inherit;
      }
      main ul li {
        margin: 0.3rem 0;
      }
      footer {
        border-top: 1px solid var(--color-border);
        padding: 1.5rem 0;
        color: var(--color-muted);
        font-size: 0.85rem;
        background: white;
      }
      footer .container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
      }
      footer a {
        color: var(--color-link);
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="brand" href="/">Substrate</a>
        <nav>
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <div>
          Code:
          <a href="https://opensource.org/licenses/MIT">MIT</a> &middot; Content:
          <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0</a>
        </div>
        <div>
          <a href="https://github.com/op4z/substrate">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
