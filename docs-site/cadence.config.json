{
  "$schema": "https://cadence.dev/schema.json",
  "version": "0.8.0",
  "project": {
    "name": "cadence-docs-site",
    "shortCode": "DOC",
    "description": ""
  },
  "stacks": [
    "typescript"
  ],
  "paths": {
    "backend": "apps/backend",
    "frontend": "apps/frontend",
    "packagesTs": "packages/typescript",
    "packagesPython": "packages/python",
    "docs": "docs",
    "auto": "auto"
  },
  "defaults": {
    "audits": [
      "pre-merge",
      "dependencies",
      "dead-code",
      "security",
      "performance",
      "functionality-gaps",
      "trend",
      "all",
      "api-contract",
      "reusability",
      "extensibility",
      "frontend",
      "package"
    ],
    "standards": [
      "cross-cutting/markdown-format-specification",
      "cross-cutting/rules",
      "frontend/accessibility",
      "frontend/data-management",
      "frontend/logging",
      "frontend/performance",
      "frontend/react",
      "frontend/testing",
      "frontend/typescript",
      "infrastructure/ci-cd",
      "infrastructure/docker",
      "operations/feature-flags",
      "operations/runbooks"
    ],
    "scaffolds": [
      "package-ts"
    ],
    "workflows": []
  },
  "bridges": {
    "claude": {
      "enabled": true,
      "commandsDir": ".claude/commands"
    },
    "cursor": {
      "enabled": false
    },
    "mcp": {
      "enabled": false
    }
  },
  "knowledge": {
    "sources": [
      "docker-compose.yml",
      ".env.example"
    ],
    "redactPatterns": [
      "PASSWORD",
      "TOKEN",
      "SECRET",
      "KEY"
    ]
  },
  "extensions": {
    "taskAdapter": null,
    "vcsAdapter": null
  },
  "telemetry": {
    "enabled": false
  }
}
