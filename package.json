{
  "name": "cadence-monorepo",
  "version": "0.8.0",
  "description": "Cadence workspace root. The publishable CLI lives in packages/cadence/.",
  "license": "MIT",
  "author": "Beau Goldberg",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs-site"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docs:dev": "npm run docs:dev --workspace cadence-docs-site",
    "docs:build": "npm run docs:build --workspace cadence-docs-site"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
