node_modules/
# Only ignore nested dist/ dirs (per-package build output). The top-level
# dist/ tree under the repo root is reserved for checked-in artifacts:
# v0.8 ships dist/action/index.js as the GitHub Action entrypoint, which
# MUST be committed (GitHub fetches it directly when the action is
# consumed from `uses: <repo>@<ref>`).
**/dist/
!/dist/
/dist/*
!/dist/action/
coverage/
*.log
.astro/
docs-site/dist/
.DS_Store
.env
.env.local
*.tsbuildinfo

# Test scratch areas
/tmp/
test-output/
.vitest-cache/

# Staged CHANGELOG copy for the substrate package (workspace-root
# CHANGELOG is the canonical source; the package copy is staged on
# `npm pack` via prepack — see scripts/copy-changelog.mjs).
/packages/substrate/CHANGELOG.md

